# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Perplexity API (for AI booking agent)
PPLX_API_KEY=your_perplexity_api_key_here

# Twilio (voice calls + WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google Gemini (traffic + weather)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Facebook (optional social posting)
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_GROUP_ID=your_facebook_group_id_here

# Driver info
DRIVER_PHONE=+523221175350
DRIVER_NAME=Bones
DRIVER_AREA=Puerto Vallarta and surrounding

# App URL (set to your Vercel deployment URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin secret — protects the /api/driving-mode endpoint
# Set a strong random value in production. Leave empty to disable auth (dev only).
ADMIN_SECRET=your_strong_random_secret_here
